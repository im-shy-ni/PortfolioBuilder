
@model PortfolioBuilder.ViewModels.RegisterViewModel
@{
    ViewData["Title"] = "Register";
}
<h2>Register</h2>
<form method="post" asp-action="Register">
  <div class="mb-2"><input asp-for="Username" class="form-control" placeholder="Username" /></div>
  <div class="mb-2"><input asp-for="Email" class="form-control" placeholder="Email" /></div>
  <div class="mb-2"><input asp-for="FullName" class="form-control" placeholder="Full name" /></div>
  <div class="mb-2"><input asp-for="Password" class="form-control" placeholder="Password" /></div>
  <div class="mb-2"><input asp-for="ConfirmPassword" class="form-control" placeholder="Confirm password" /></div>
  <button class="btn btn-accent">Register</button>
</form>
<p class="mt-2">After registering you will receive a confirmation email (check the Emails folder).</p>
